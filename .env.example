# Postgres connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=threat_intel
POSTGRES_USER=threat_intel
POSTGRES_PASSWORD=change_me_in_real_env

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# HTTP behavior
HTTP_USER_AGENT=threat-intel-attack-trends/0.1 (research; contact: your-email@example.com)
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3

# ATT&CK
ATTACK_VERSION=v15.1
ATTACK_BUNDLE_URL=https://raw.githubusercontent.com/mitre/cti/ATT%26CK-v15.1/enterprise-attack/enterprise-attack.json
